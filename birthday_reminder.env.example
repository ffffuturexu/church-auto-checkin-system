BIRTHDAY_REMINDER_DRY_RUN=false
BIRTHDAY_REMINDER_RECIPIENTS=""
BIRTHDAY_SMTP_HOST="smtp.gmail.com"
BIRTHDAY_SMTP_PORT=587
BIRTHDAY_SMTP_FROM="noreply@example.com"
BIRTHDAY_SMTP_USERNAME="your@gmail.com"
BIRTHDAY_SMTP_PASSWORD="(app-password)"
# Optional: 0 for same-day
BIRTHDAY_REMINDER_DAYS_AHEAD=0

